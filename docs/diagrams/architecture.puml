@startuml architecture
!pragma layout smetana
title dropicture Infrastructure (Terraform)
footer Author: Amir Redjem   |   2026-06-05   |   v1.2

skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam roundCorner 12
skinparam ArrowColor #2F6FED
skinparam ArrowFontColor #41505F
skinparam cloudBackgroundColor #FFF6EC
skinparam cloudBorderColor #F3B27A
skinparam nodeBackgroundColor #FDF4F4
skinparam nodeBorderColor #E6BCBC
skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #B8C4D0
skinparam databaseBackgroundColor #FFFFFF
skinparam databaseBorderColor #B7E0C9
skinparam componentBackgroundColor #F6F1FC
skinparam componentBorderColor #CDBCE8

actor "User" as user

cloud "Cloudflare\nDNS, proxy, edge TLS" as cf {
  rectangle "**data cloudflare_zone**\nlookup zone by name -> zone_id" as zone
  rectangle "**cloudflare_dns_record** (apex @ + www)\nA, proxied, ttl=1\ncontent = manager.ipv4_address" as dns
  rectangle "**cloudflare_origin_ca_certificate**\norigin-rsa, validity 5475d\ndropicture.com + *.dropicture.com" as cert
}

node "Hetzner Cloud\nfsn1 / eu-central" as htz {
  rectangle "**hcloud_firewall.app**\nin 80/443  <-  Cloudflare CIDRs only\nin 22 + ICMP  <-  anywhere\n(SSH key-only, enforced by Ansible)" as fw
  rectangle "**hcloud_ssh_key.deploy**\npublic key (base64 var), root account" as ssh

  node "**hcloud_server.manager**   (single server)\nrole = swarm-manager — single-node Docker Swarm\ncpx32 (4 vCPU / 8 GB / 160 GB SSD), ubuntu-24.04\npublic IPv4/IPv6 only — no private network" as srv {
    component "Docker Engine — Swarm mode\nswarm init (no join)\nworkloads + media on the local SSD\n//outside Terraform, via Ansible//" as app
  }
}

node "Terraform\nIaC >= 1.10" as tf {
  rectangle "**providers**\nhcloud ~>1.45, cloudflare ~>5\ntls ~>4.0, http ~>3.4" as tfcli
  rectangle "**tls_private_key.origin** (RSA 2048, prevent_destroy)\n+ **tls_cert_request.origin** (CSR)" as tlskey
  rectangle "**data http cloudflare_ipv4 / ipv6**\nfetch Cloudflare IP ranges" as cfips
  database "**S3 backend** (remote state)\nbucket dropicture-tfstate-prod\nencrypted, lockfile, eu-west-3" as state
}

user --> dns : HTTPS 443 / TLS
dns --> fw : reverse proxy\nFull (strict)
fw --> srv : ingress 80/443
zone ..> dns : zone_id
ssh ..> srv : ssh_keys

tlskey ..> cert : CSR
cert ..> app : origin cert + key (PEM)\nTF outputs -> Ansible

cfips ..> fw : source_ips (CIDRs)
tfcli ..> htz : provisions\nhcloud API
tfcli ..> cf : provisions\nCloudflare API
tfcli ..> state : state (S3)

@enduml
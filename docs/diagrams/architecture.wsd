@startuml architecture
!pragma layout smetana
title dropicture Infrastructure (Terraform)
footer Author: Amir Redjem   |   2026-06-01   |   v1.0

skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam roundCorner 12
skinparam ArrowColor #2F6FED
skinparam ArrowFontColor #41505F
skinparam cloudBackgroundColor #FFF6EC
skinparam cloudBorderColor #F3B27A
skinparam nodeBackgroundColor #FDF4F4
skinparam nodeBorderColor #E6BCBC
skinparam frameBackgroundColor #EEF4FF
skinparam frameBorderColor #B8CDF3
skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #B8C4D0
skinparam databaseBackgroundColor #FFFFFF
skinparam databaseBorderColor #B7E0C9
skinparam componentBackgroundColor #F6F1FC
skinparam componentBorderColor #CDBCE8

actor "User" as user

cloud "Cloudflare\nDNS, WAF, edge TLS" as cf {
  rectangle "**cloudflare_dns_record**\nA apex + www, proxied" as dns
  rectangle "**cloudflare_origin_ca_certificate**\nRSA 2048, *.dropicture.com" as cert
}

node "Hetzner Cloud\nfsn1, eu-central" as htz {
  rectangle "**hcloud_firewall**\n80/443 (Cloudflare)\n22/4646/ICMP (admin_ips)" as fw
  rectangle "**hcloud_ssh_key.deploy**\npublic key, root account" as ssh

  frame "**hcloud_network**\n10.0.0.0/16, subnet 10.0.1.0/24" as net {
    node "**hcloud_server.app[0]**\ncpx32, ubuntu-24.04\nprivate 10.0.1.10, public IPv4/IPv6" as srv {
      component "Nomad + Garage\n//(outside Terraform)//\nprovisioned via Ansible" as app
    }
    database "**hcloud_volume.media[0]**\n50 GB, ext4, automount\nobject-storage" as vol
  }
}

node "Terraform\nIaC >= 1.10" as tf {
  rectangle "**terraform**\nhcloud, cloudflare, tls, http" as tfcli
  database "**S3 backend**\nremote state\nencrypted, locked, eu-west-3" as state
}

user --> dns : HTTPS 443 / TLS
dns --> fw : reverse proxy\nHTTPS, Full strict
fw --> srv : ingress 80/443
srv --> vol : mount (ext4)
tfcli ..> htz : provisions\nhcloud API
tfcli ..> cf : provisions\nCloudflare API
tfcli ..> state : state (S3)

@enduml

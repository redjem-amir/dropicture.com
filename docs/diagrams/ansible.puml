@startuml ansible
title dropicture - Ansible provisioning (Nomad cluster)
footer Author: Amir Redjem   |   2026-06-03   |   v1.0

skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam ArrowColor #2F6FED
skinparam ArrowFontColor #41505F
skinparam sequenceMessageAlign center
skinparam ParticipantBackgroundColor #FDF4F4
skinparam ParticipantBorderColor #E6BCBC
skinparam ActorBackgroundColor #EEF4FF
skinparam ActorBorderColor #B8CDF3
skinparam DatabaseBackgroundColor #FFFFFF
skinparam DatabaseBorderColor #B7E0C9
skinparam CollectionsBackgroundColor #FDF4F4
skinparam CollectionsBorderColor #E6BCBC
skinparam ControlBackgroundColor #F6F1FC
skinparam ControlBorderColor #CDBCE8
skinparam SequenceLifeLineBorderColor #B8C4D0
skinparam SequenceDividerBackgroundColor #EEF4FF
skinparam SequenceDividerFontColor #41505F
skinparam SequenceGroupBackgroundColor #F6F1FC
skinparam SequenceGroupBorderColor #CDBCE8
skinparam SequenceGroupHeaderFontColor #41505F
skinparam noteBackgroundColor #FFF6EC
skinparam noteBorderColor #F3B27A

actor "Operator / CI" as op
participant "Ansible\ncontrol node\n(localhost)" as ans
database "S3 backend\ntfstate (eu-west-3)" as s3
collections "Nomad nodes\nservers + clients\n(SSH root)" as nodes
control "Nomad API\nserver[0]:4646" as api
database "AWS Secrets\nManager" as sm

== Play 1 - Discover nodes from Terraform state (localhost) ==
op -> ans : ansible-playbook playbook.yml\nAWS creds + SSH_PRIVATE_KEY_B64
ans -> ans : assert required env vars
ans -> s3 : GET terraform.tfstate
s3 --> ans : state JSON
ans -> ans : parse outputs\n(server/client public + private IPs)
ans -> ans : delete local state copy (sensitive)
ans -> ans : write SSH key to tempfile (0600)
ans -> ans : add_host -> groups\nnomad_servers / nomad_clients

== Play 2 - Configure the Nomad cluster (hosts: nomad, over SSH) ==
ans -> nodes : add HashiCorp apt repo,\ninstall Nomad 2.0.2-1
ans -> nodes : install Docker + CNI 1.6.2,\nbridge modules + sysctls
ans -> nodes : template /etc/nomad.d/nomad.hcl
note over nodes
  server block on servers only
  (bootstrap_expect = #servers, retry_join)
  client block on every node
  ACL enabled, UI disabled
  datacenter dc1 / region global
end note
ans -> nodes : enable & start nomad\n(handler: restart on config change)

== Play 3 - Bootstrap ACL + store token (localhost, first run only) ==
ans -> sm : secret exists?\nnomad/dropicture/management-token
alt secret missing (first run)
  ans -> api : wait for :4646, then\nPOST /v1/acl/bootstrap
  api --> ans : SecretID (management token)
  ans -> sm : store management token
else already bootstrapped
  ans -> ans : skip bootstrap
end

== Play 4 - Reconcile cluster with Terraform inventory (localhost) ==
ans -> sm : fetch management token
sm --> ans : token
ans -> api : GET /v1/agent/members
api --> ans : current servers
ans -> api : force-leave + prune\nservers not in TF state
ans -> api : GET /v1/nodes
api --> ans : current clients
ans -> api : purge client nodes\nnot in TF state

== Play 5 - Clean up (localhost) ==
ans -> ans : remove temporary SSH key

@enduml

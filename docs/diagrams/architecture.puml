@startuml architecture
!pragma layout smetana
title dropicture Infrastructure (Terraform)
footer Author: Amir Redjem   |   2026-06-03   |   v1.1

skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam roundCorner 12
skinparam ArrowColor #2F6FED
skinparam ArrowFontColor #41505F
skinparam cloudBackgroundColor #FFF6EC
skinparam cloudBorderColor #F3B27A
skinparam nodeBackgroundColor #FDF4F4
skinparam nodeBorderColor #E6BCBC
skinparam frameBackgroundColor #EEF4FF
skinparam frameBorderColor #B8CDF3
skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #B8C4D0
skinparam databaseBackgroundColor #FFFFFF
skinparam databaseBorderColor #B7E0C9
skinparam componentBackgroundColor #F6F1FC
skinparam componentBorderColor #CDBCE8

actor "User" as user

cloud "Cloudflare\nDNS, proxy, edge TLS" as cf {
  rectangle "**data cloudflare_zone**\nlookup zone by name -> zone_id" as zone
  rectangle "**cloudflare_dns_record** (apex @ + www)\nA, proxied, ttl=1\ncontent = server[0].ipv4_address" as dns
  rectangle "**cloudflare_origin_ca_certificate**\norigin-rsa, validity 5475d\ndropicture.com + *.dropicture.com" as cert
}

node "Hetzner Cloud\nfsn1 / eu-central" as htz {
  rectangle "**hcloud_firewall.app**\nin 80/443  <-  Cloudflare CIDRs\nin 22/4646/ICMP  <-  admin_ips" as fw
  rectangle "**hcloud_ssh_key.deploy**\npublic key, root account" as ssh

  frame "**hcloud_network.main**  10.0.0.0/16\n**hcloud_network_subnet.nodes**  10.0.1.0/24 (cloud)" as net {

    node "**hcloud_server.server[*]**   (count = server_count = 1)\nrole = nomad-server (master / Raft)\ncpx32, ubuntu-24.04\nprivate 10.0.1.10+i, public IPv4/IPv6" as srv {
      component "Nomad server + workloads\nGarage (S3 object store)\n//outside Terraform, via Ansible//" as appsrv
    }
    database "**hcloud_volume.server_media[*]**\n50 GB ext4, automount\nlabel: object-storage" as svol

    node "**hcloud_server.client[*]**   (count = client_count = 0)\nrole = nomad-client (worker)\ncpx32, ubuntu-24.04\nprivate 10.0.1.100+i, public IPv4/IPv6" as cli {
      component "Nomad client / workloads\n//outside Terraform, via Ansible//" as appcli
    }
    database "**hcloud_volume.client_media[*]**\n50 GB ext4, automount\nlabel: object-storage" as cvol
  }
}

node "Terraform\nIaC >= 1.10" as tf {
  rectangle "**providers**\nhcloud ~>1.45, cloudflare ~>5\ntls ~>4.0, http ~>3.4" as tfcli
  rectangle "**data http cloudflare_ipv4 / ipv6**\nfetch Cloudflare IP ranges" as cfips
  database "**S3 backend** (remote state)\nbucket dropicture-tfstate-prod\nencrypted, lockfile, eu-west-3" as state
}

user --> dns : HTTPS 443 / TLS
dns --> fw : reverse proxy\nFull (strict)
fw --> srv : ingress 80/443
fw ..> cli : ingress 80/443\n(when client_count > 0)
srv --> svol : attach (ext4)
cli ..> cvol : attach (ext4)
zone ..> dns : zone_id

cfips ..> fw : source_ips (CIDRs)
tfcli ..> htz : provisions\nhcloud API
tfcli ..> cf : provisions\nCloudflare API
tfcli ..> state : state (S3)

@enduml
